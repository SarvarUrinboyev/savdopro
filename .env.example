# Copy to .env (gitignored) and set real values. Used by docker-compose.yml.

# --- Postgres (shared instance; backend + license use SEPARATE databases) ---
DB_USER=savdopro
DB_PASSWORD=change-me-to-a-strong-password
DB_NAME=savdopro

# --- Shared JWT signing key ---
# Backend and license MUST use the SAME 64+ char random value. A mismatch =
# login works but every /api call returns 401. Generate one with e.g.
#   openssl rand -base64 48
SAVDOPRO_JWT_SECRET=replace-with-a-64-plus-character-random-string

# --- Super-admin bootstrap (change the password right after first login) ---
SAVDOPRO_ADMIN_USER=admin
SAVDOPRO_ADMIN_PASSWORD=change-me-admin-password
SAVDOPRO_ADMIN_NAME=Super Admin
