# --- Java / Maven ---
target/
*.class
*.jar
!.mvn/wrapper/maven-wrapper.jar

# --- Local secrets (never commit) ---
backend/application-local.properties
**/application-local.properties
.env
# Local dev-runner launchers — contain a dev JWT secret passed via -D
_dev-*.bat
_dev-*.cmd
_dev-*.sh
# Local DB backups / dumps (may contain tenant data)
backups/
backend/backups/

# --- Node / frontend ---
node_modules/
frontend/dist/
# Frontend build output is copied here at build time:
backend/src/main/resources/static/

# --- Electron ---
electron/dist/
electron/out/
electron/resources/
# Bundled Java runtime (downloaded at build time, ~145 MB):
electron/jre/

# --- Embedded H2 database files (created at runtime) ---
*.mv.db
*.trace.db

# --- Build tools (downloaded locally) ---
.tools/

# --- IDE / OS ---
.idea/
.vscode/
*.iml
*.ipr
*.iws
.DS_Store
Thumbs.db
desktop.ini

# --- Logs ---
*.log
logs/
build_*.txt

# Mobile server H2 runtime DB (regenerated at runtime)
mobile/server/data/
*.lock.db

# --- Local working docs (not part of the product) ---
savdopro_audit_prompt_v2.md
