# =====================================================================
#  SavdoPRO License Server — environment template
#
#  Copy to `.env` on the VPS, then fill in the REAL values. Never commit
#  the populated .env to git (already covered by .dockerignore + .gitignore).
#
#  Quick way to generate strong secrets:
#    openssl rand -base64 48   # for SAVDOPRO_JWT_SECRET (64+ chars)
#    openssl rand -base64 24   # for POSTGRES_PASSWORD
#    openssl rand -base64 18   # for SAVDOPRO_ADMIN_PASSWORD
# =====================================================================

# --- PostgreSQL ---
POSTGRES_USER=license
POSTGRES_DB=license
# 24+ random chars. Change before first `docker compose up`.
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# --- JWT signing key ---
# 64+ random chars. If you rotate this, every issued token immediately
# becomes invalid and every desktop client must log back in.
SAVDOPRO_JWT_SECRET=CHANGE_ME_JWT_SECRET_AT_LEAST_64_RANDOM_CHARS_LONG_XXXXXXXXXXXXXXXXXX

# --- Super-admin bootstrap credentials ---
# These are used ONLY on the very first startup (when the accounts table
# is empty). After login, change the password from the browser admin
# panel — these env vars are no longer consulted for existing users.
SAVDOPRO_ADMIN_USER=admin
SAVDOPRO_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
SAVDOPRO_ADMIN_NAME=Super Admin

# --- Network binding ---
# 0.0.0.0 → reachable from the public internet on port 9090.
# 127.0.0.1 → only reachable from a reverse proxy on the same host
#             (recommended once you put Caddy / nginx in front).
LICENSE_BIND=0.0.0.0

# --- Billing / payment providers (optional; leave blank to disable) ---
# Until you fill these, /api/billing/checkout rejects that provider with a
# clear "not configured" message and the Payme endpoint refuses all calls.
# The signing algorithms are already implemented — only the merchant
# credentials (from your Click / Payme cabinet) go here.
#
# Generic webhook stub (used only if you keep the placeholder webhook):
BILLING_WEBHOOK_SECRET=
# Click SHOP-API (docs.click.uz) — from your Click merchant cabinet:
BILLING_CLICK_SERVICE_ID=
BILLING_CLICK_MERCHANT_ID=
BILLING_CLICK_SECRET_KEY=
BILLING_CLICK_CHECKOUT_BASE_URL=https://my.click.uz/services/pay
BILLING_CLICK_RETURN_URL=
# Payme / Paycom Merchant API (developer.help.paycom.uz):
BILLING_PAYME_MERCHANT_ID=
BILLING_PAYME_MERCHANT_KEY=
# The order key you registered in the Payme cabinet (echoed back in "account"):
BILLING_PAYME_ACCOUNT_FIELD=order_id
BILLING_PAYME_CHECKOUT_BASE_URL=https://checkout.paycom.uz

# --- Error tracking (Sentry; optional) ---
# Blank = Sentry disabled (no-op). Set the DSN in production to auto-report
# unhandled exceptions. traces-sample-rate 0 = errors only (no perf overhead).
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0
