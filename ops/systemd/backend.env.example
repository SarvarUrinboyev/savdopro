# =====================================================================
#  /etc/savdopro/backend.env  — savdopro-backend production environment
#  Owner root:savdopro, mode 0600:   chmod 600 /etc/savdopro/backend.env
#                                     chown root:savdopro /etc/savdopro/backend.env
#  This file REPLACES the 644 /opt/barakat/application-local.properties. Move
#  every real secret here, then delete (or empty) that properties file so it
#  stops overriding the prod profile (notably any ddl-auto=update line).
#  Placeholders only in this .example — never commit real values.
# =====================================================================

# --- Activate the prod profile in ONE place (env, not the command line) ---
SPRING_PROFILES_ACTIVE=prod

# --- Database (hosted Postgres; separate DB from the license server) ---
DB_URL=jdbc:postgresql://localhost:5432/savdopro
DB_USER=savdopro
DB_PASSWORD=__STRONG_DB_PASSWORD__

# --- Schema safety rollout ---
# Leave UNSET to use the prod default (validate). For the FIRST cautious
# prod-profile deploy, set to none, confirm the app is healthy, then remove
# this line to switch to validate (see runbook Phase 4).
# SPRING_JPA_HIBERNATE_DDL_AUTO=none

# --- Shared JWT secret (MUST match the license server byte-for-byte) ---
SAVDOPRO_JWT_SECRET=__64_PLUS_CHAR_RANDOM__

# --- Super-admin bootstrap (change password right after first login) ---
SAVDOPRO_ADMIN_USER=admin
SAVDOPRO_ADMIN_PASSWORD=__STRONG_ADMIN_PASSWORD__
SAVDOPRO_ADMIN_NAME=Super Admin

# --- CORS: explicit prod origin(s), comma-separated. Fails closed if empty. ---
WEB_ALLOWED_ORIGINS=https://167-172-164-214.nip.io

# --- Reverse proxy (nginx on loopback) ---
TRUST_PROXY_HEADERS=true
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# --- Owner Telegram report bot ---
# chat id is NOT secret; the bot TOKEN is. Both live here (0600) rather than in
# a world-readable properties file. Fix "chat not found" per runbook Phase 6.
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=__OWNER_BOT_TOKEN__
TELEGRAM_CHAT_IDS=__VERIFIED_CHAT_ID__

# --- Error tracking (optional; blank disables Sentry) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
