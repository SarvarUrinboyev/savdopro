# =====================================================================
#  /etc/savdopro/license.env  — savdopro-license production environment
#  Owner root:savdopro-license, mode 0600.
#  Placeholders only — never commit real values.
# =====================================================================

# --- Bind to loopback; nginx is the sole ingress (verify nginx upstream is
#     127.0.0.1:9090 before applying). Defence in depth on top of the firewall. ---
SERVER_ADDRESS=127.0.0.1
# Honour X-Forwarded-Proto from nginx so Spring emits HSTS.
FORWARD_HEADERS_STRATEGY=framework
TRUST_PROXY_HEADERS=true
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# --- Database ---
# CURRENT (H2) — keep for v2.3.4 hardening; note the ABSOLUTE path so it does
# not depend on WorkingDirectory. /opt/savdopro must stay writable for .mv.db.
SPRING_DATASOURCE_URL=jdbc:h2:file:/opt/savdopro/license-data;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE
SPRING_DATASOURCE_USERNAME=__H2_USER__
SPRING_DATASOURCE_PASSWORD=__STRONG_H2_PASSWORD__
SPRING_DATASOURCE_DRIVER=org.h2.Driver
# AFTER the Postgres migration (see license-server-postgres-migration-plan.md),
# replace the four lines above with:
#   SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/savdopro_license
#   SPRING_DATASOURCE_USERNAME=savdopro_license
#   SPRING_DATASOURCE_PASSWORD=__STRONG__
#   SPRING_DATASOURCE_DRIVER=org.postgresql.Driver
#   HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# --- Shared JWT secret (identical to backend.env) ---
SAVDOPRO_JWT_SECRET=__64_PLUS_CHAR_RANDOM__

# --- Super-admin bootstrap ---
SAVDOPRO_ADMIN_USER=admin
SAVDOPRO_ADMIN_PASSWORD=__STRONG_ADMIN_PASSWORD__

# --- Security-alert Telegram bot (login lockouts, new-signup pings) ---
SAVDOPRO_LICENSE_ALERT_BOT_TOKEN=__ALERT_BOT_TOKEN__
SAVDOPRO_LICENSE_ALERT_CHAT_ID=__VERIFIED_CHAT_ID__

# --- Error tracking (optional) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Prometheus scrape token — /actuator/prometheus uchun statik bearer token.
# Bo'sh = o'chiq (endpoint faqat JWT bilan). Ikkala servisda BIR XIL qiymat.
# Yaratish: openssl rand -hex 32   (ops/monitoring/ stack shu tokenni ishlatadi)
METRICS_SCRAPE_TOKEN=
