# Copy to .env (gitignored) and fill in. Used by docker-compose.monitoring.yml.

# Grafana admin login (http://localhost:3001 over the SSH tunnel).
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=

# Telegram delivery for Grafana alerts (service down / error rate / heap).
# Reuse the owner-report bot or a dedicated one; get the chat id by messaging
# the bot once and calling https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# NOTE the scrape token is NOT read from this file — write it to
# secrets/scrape-token (single line, no newline is fine):
#   mkdir -p secrets && printf '%s' "<value of METRICS_SCRAPE_TOKEN>" > secrets/scrape-token
# It must equal METRICS_SCRAPE_TOKEN in /etc/savdopro/backend.env and license.env.
