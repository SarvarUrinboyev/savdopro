# =====================================================================
#  savdopro-backend — production environment (TEMPLATE — placeholders only)
#  Install on the NEW server as:  /etc/savdopro/backend.env
#  Permissions:  chown root:root /etc/savdopro/backend.env && chmod 600 it
#  Referenced by the systemd unit via:  EnvironmentFile=/etc/savdopro/backend.env
#
#  NEVER commit real values. Fill __SET_ME__ / __PLACEHOLDER__ on the server only.
# =====================================================================

# --- Profile + bind (prod = Swagger off, CSP/HSTS, CORS fail-closed, demo-seed off) ---
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8086
SERVER_ADDRESS=127.0.0.1            # loopback only; nginx is the sole ingress

# --- PostgreSQL (the restored `barakat` database) ---
# The prod profile also accepts DB_URL / DB_USER / DB_PASSWORD; SPRING_DATASOURCE_*
# bind via relaxed binding and take precedence — either set works, don't set both.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/barakat
SPRING_DATASOURCE_USERNAME=barakat
SPRING_DATASOURCE_PASSWORD=__SET_ME__
# Schema is owned by Flyway; Hibernate must never mutate it.
SPRING_JPA_HIBERNATE_DDL_AUTO=none

# --- CORS: the public origin(s) of the NEW deployment, comma-separated. Fail-closed. ---
WEB_ALLOWED_ORIGINS=https://__NEW_PUBLIC_HOST__

# --- Reverse proxy (nginx on loopback) ---
TRUST_PROXY_HEADERS=true
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# --- Demo/staging seed: HARD OFF in production ---
ALLOW_DEMO_SEED=false
DEMO_SEED_ENABLED=false

# --- Shared JWT secret (MUST be byte-identical in license.env) ---
# Generate: openssl rand -base64 48
SAVDOPRO_JWT_SECRET=__64_PLUS_CHAR_RANDOM__

# --- Super-admin bootstrap (change password right after first login) ---
SAVDOPRO_ADMIN_USER=admin
SAVDOPRO_ADMIN_PASSWORD=__STRONG_ADMIN_PASSWORD__
SAVDOPRO_ADMIN_NAME=Super Admin

# --- Owner Telegram report bot (optional; blank disables) ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=__PLACEHOLDER__
TELEGRAM_CHAT_IDS=__PLACEHOLDER__

# --- SMS gateway Eskiz (optional; blank disables). ROTATE the old password. ---
SMS_ENABLED=false
SMS_ESKIZ_EMAIL=__PLACEHOLDER__
SMS_ESKIZ_PASSWORD=__PLACEHOLDER__
SMS_FROM=4546

# --- Online payments Click/Payme (optional; blank disables) ---
PAYME_ENABLED=false
PAYME_MERCHANT_ID=__PLACEHOLDER__
PAYME_KEY=__PLACEHOLDER__
CLICK_ENABLED=false
CLICK_SERVICE_ID=__PLACEHOLDER__
CLICK_MERCHANT_ID=__PLACEHOLDER__
CLICK_SECRET_KEY=__PLACEHOLDER__
CLICK_MERCHANT_USER_ID=__PLACEHOLDER__

# --- Transactional email SMTP (optional; blank disables) ---
EMAIL_ENABLED=false
SMTP_HOST=__PLACEHOLDER__
SMTP_USER=__PLACEHOLDER__
SMTP_PASSWORD=__PLACEHOLDER__

# --- AI providers (optional; blank disables the assistant) ---
AI_PROVIDERS=__PLACEHOLDER__
# (gemini / nvidia / openrouter keys as needed — placeholders only)

# --- Error tracking (optional) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Prometheus scrape token — /actuator/prometheus uchun statik bearer token.
# Bo'sh = o'chiq (endpoint faqat JWT bilan). Ikkala servisda BIR XIL qiymat.
# Yaratish: openssl rand -hex 32   (ops/monitoring/ stack shu tokenni ishlatadi)
METRICS_SCRAPE_TOKEN=

# Hikari DB pool (ixtiyoriy): 1GB box -> 5, 2GB -> 10 (default), 4GB -> 15-20
#DB_POOL_MAX=10

# --- AI yordamchi (barchasi ixtiyoriy; bo'sh = provayder o'chiq) ---
# Zanjir tartibi: gemini -> nvidia-deepseek -> nvidia-kimi -> openrouter
# (xato/limit bo'lsa keyingisiga o'tadi; hammasi o'chiq bo'lsa AI degraded
# rejimda KPI-snapshot qaytaradi). Holat: startup logida "AI chain (N ready...)"
# Kalit olish:
#   GEMINI_API_KEY      https://aistudio.google.com/apikey (bepul tier bor)
#   NVIDIA_DEEPSEEK_KEY https://build.nvidia.com (bepul NIM kaliti)
#   NVIDIA_KIMI_KEY     o'sha NVIDIA kaliti bilan bir xil bo'lishi mumkin
#   OPENROUTER_API_KEY  https://openrouter.ai/keys (pullik, oxirgi zaxira)
GEMINI_API_KEY=
NVIDIA_DEEPSEEK_KEY=
NVIDIA_KIMI_KEY=
OPENROUTER_API_KEY=
