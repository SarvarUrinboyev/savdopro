# =====================================================================
#  savdopro-license — production environment (TEMPLATE — placeholders only)
#  Install on the NEW server as:  /etc/savdopro/license.env   (chmod 600, root:root)
#  Referenced by the systemd unit via:  EnvironmentFile=/etc/savdopro/license.env
#
#  NEVER commit real values.
# =====================================================================

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=9090
SERVER_ADDRESS=127.0.0.1            # loopback only; nginx is the sole ingress
# TLS terminates at nginx — honour X-Forwarded-Proto so HSTS is emitted.
FORWARD_HEADERS_STRATEGY=framework
TRUST_PROXY_HEADERS=true
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# --- Database: H2 file (copied from the old server as license-data.mv.db) ---
# H2 appends ".mv.db" to this path, so the file must be /opt/savdopro/license-data.mv.db
SPRING_DATASOURCE_URL=jdbc:h2:file:/opt/savdopro/license-data;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE
SPRING_DATASOURCE_USERNAME=__SET_ME__
SPRING_DATASOURCE_PASSWORD=__SET_ME__
SPRING_DATASOURCE_DRIVER=org.h2.Driver
# (H2→PostgreSQL migration is a later P1 — see README §15; not needed for this move.)

# --- Shared JWT secret — MUST equal backend.env SAVDOPRO_JWT_SECRET byte-for-byte ---
SAVDOPRO_JWT_SECRET=__SAME_AS_BACKEND__

# --- Super-admin bootstrap ---
SAVDOPRO_ADMIN_USER=admin
SAVDOPRO_ADMIN_PASSWORD=__STRONG_ADMIN_PASSWORD__

# --- Security-alert Telegram bot (optional) ---
SAVDOPRO_LICENSE_ALERT_BOT_TOKEN=__PLACEHOLDER__
SAVDOPRO_LICENSE_ALERT_CHAT_ID=__PLACEHOLDER__

# --- Social login (optional; blank hides the buttons) ---
SAVDOPRO_LICENSE_TG_OAUTH_BOT_TOKEN=__PLACEHOLDER__
SAVDOPRO_LICENSE_TG_OAUTH_BOT_USERNAME=__PLACEHOLDER__
SAVDOPRO_GOOGLE_CLIENT_ID=__PLACEHOLDER__
SAVDOPRO_FB_APP_ID=__PLACEHOLDER__
SAVDOPRO_FB_APP_SECRET=__PLACEHOLDER__

# --- Billing / PSP (optional) ---
BILLING_CLICK_SERVICE_ID=__PLACEHOLDER__
BILLING_CLICK_MERCHANT_ID=__PLACEHOLDER__
BILLING_CLICK_SECRET_KEY=__PLACEHOLDER__
BILLING_PAYME_MERCHANT_ID=__PLACEHOLDER__
BILLING_PAYME_MERCHANT_KEY=__PLACEHOLDER__

# --- SMS provider (optional; default = log only). ROTATE the old Eskiz password. ---
SMS_PROVIDER=__PLACEHOLDER__
SMS_ESKIZ_EMAIL=__PLACEHOLDER__
SMS_ESKIZ_PASSWORD=__PLACEHOLDER__

# --- Error tracking (optional) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Prometheus scrape token — /actuator/prometheus uchun statik bearer token.
# Bo'sh = o'chiq (endpoint faqat JWT bilan). Ikkala servisda BIR XIL qiymat.
# Yaratish: openssl rand -hex 32   (ops/monitoring/ stack shu tokenni ishlatadi)
METRICS_SCRAPE_TOKEN=
